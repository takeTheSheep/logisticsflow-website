---
import SystemIcon from '@/components/common/SystemIcon.astro';
import type { ServiceItem } from '@/types/content';

interface Props {
  service: ServiceItem;
}

const { service } = Astro.props as Props;
---

<section id={service.id} class="scroll-mt-28 rounded-3xl border border-white/10 bg-white/10 p-6 md:p-8" data-reveal>
  <div class="flex flex-wrap items-center justify-between gap-4">
    <div class="flex items-center gap-3">
      <SystemIcon name={service.icon} size="lg" />
      <h2 class="text-2xl font-semibold text-white md:text-3xl">{service.title}</h2>
    </div>
    <span class="rounded-full border border-cyan-200/45 bg-cyan-200/20 px-3 py-1 text-xs font-semibold uppercase tracking-[0.12em] text-cyan-50">
      {service.signal}
    </span>
  </div>

  <p class="mt-3 text-slate-300">{service.summary}</p>

  <div class="mt-6 grid gap-4 lg:grid-cols-2">
    <article class="rounded-2xl border border-white/10 bg-white/10 p-4">
      <h3 class="text-sm font-semibold uppercase tracking-[0.1em] text-cyan-100/85">Business Problem</h3>
      <p class="mt-3 text-sm text-slate-300">{service.problem}</p>
    </article>
    <article class="rounded-2xl border border-white/10 bg-white/10 p-4">
      <h3 class="text-sm font-semibold uppercase tracking-[0.1em] text-cyan-100/85">How We Solve It</h3>
      <p class="mt-3 text-sm text-slate-300">{service.solution}</p>
    </article>
  </div>

  <div class="mt-6 grid gap-4 lg:grid-cols-2">
    <article class="rounded-2xl border border-white/10 bg-white/10 p-4">
      <h3 class="text-sm font-semibold uppercase tracking-[0.1em] text-cyan-100/85">Key Benefits</h3>
      <ul class="mt-3 space-y-2 text-sm text-slate-300">
        {service.benefits.map((benefit) => <li class="flex gap-2"><span class="mt-2 h-1.5 w-1.5 rounded-full bg-cyan-300"></span><span>{benefit}</span></li>)}
      </ul>
    </article>
    <article class="rounded-2xl border border-white/10 bg-white/10 p-4">
      <h3 class="text-sm font-semibold uppercase tracking-[0.1em] text-cyan-100/85">Process</h3>
      <ul class="mt-3 space-y-2 text-sm text-slate-300">
        {service.process.map((step, index) => <li class="flex gap-2"><span class="text-cyan-200">{index + 1}.</span><span>{step}</span></li>)}
      </ul>
    </article>
  </div>
</section>
