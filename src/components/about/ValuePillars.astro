---
import type { ValuePillar } from '@/types/content';

interface Props {
  pillars: ValuePillar[];
}

const { pillars } = Astro.props as Props;
---

<div class="grid gap-4 md:grid-cols-2">
  {
    pillars.map((pillar) => (
      <article class="rounded-2xl border border-white/10 bg-white/10 p-5">
        <h2 class="text-xl font-semibold text-white">{pillar.title}</h2>
        <p class="mt-3 text-sm text-slate-300">{pillar.description}</p>
      </article>
    ))
  }
</div>

