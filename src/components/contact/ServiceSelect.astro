---
interface ServiceSelectOption {
  value: string;
  label: string;
  description?: string;
  signal?: string;
}

interface Props {
  id?: string;
  name?: string;
  label?: string;
  placeholder?: string;
  helperText?: string;
  options: ServiceSelectOption[];
}

const {
  id = 'serviceNeeded',
  name = 'serviceNeeded',
  label = 'Service Needed',
  placeholder = 'Select a service',
  helperText = 'Choose the primary logistics module you want to discuss.',
  options,
} = Astro.props as Props;

const labelId = `${id}-label`;
const triggerId = `${id}-trigger`;
const listboxId = `${id}-listbox`;
const helperId = `${id}-helper`;
---

<div class="space-y-2">
  <label id={labelId} for={triggerId} class="mb-2 block text-sm font-medium text-slate-100">{label}</label>

  <div
    data-service-select
    data-open="false"
    data-has-value="false"
    data-placeholder={placeholder}
    data-helper-text={helperText}
    class="service-select-root relative"
  >
    <input id={id} name={name} type="hidden" value="" />

    <button
      id={triggerId}
      type="button"
      data-service-select-trigger
      data-field-proxy={name}
      class="service-select-trigger group relative flex min-h-[4rem] w-full items-center rounded-[1.125rem] border border-white/15 bg-[linear-gradient(180deg,rgba(255,255,255,0.14),rgba(255,255,255,0.08))] px-4 py-3 text-left shadow-[inset_0_1px_0_rgba(255,255,255,0.08)] transition-all duration-300 ease-refined"
      aria-haspopup="listbox"
      aria-expanded="false"
      aria-controls={listboxId}
      aria-labelledby={`${labelId} ${id}-selected`}
      aria-describedby={helperId}
    >
      <span class="pointer-events-none absolute inset-px rounded-[1rem] bg-[radial-gradient(circle_at_top,rgba(167,235,255,0.16),transparent_58%),linear-gradient(135deg,rgba(255,255,255,0.06),transparent_48%)] opacity-80"></span>

      <span class="relative flex min-w-0 flex-1 items-center gap-3">
        <span class="flex h-11 w-11 shrink-0 items-center justify-center rounded-[0.95rem] border border-cyan-200/15 bg-ink-950/25 text-cyan-100 shadow-[inset_0_1px_0_rgba(255,255,255,0.05)]">
          <svg aria-hidden="true" viewBox="0 0 24 24" class="h-5 w-5">
            <path
              d="M5 7.5h14M5 12h10M5 16.5h7"
              fill="none"
              stroke="currentColor"
              stroke-linecap="round"
              stroke-width="1.7"
            />
          </svg>
        </span>

        <span class="min-w-0 flex-1">
          <span id={`${id}-selected`} data-service-select-label class="block text-sm font-semibold text-slate-200">
            {placeholder}
          </span>
          <span id={helperId} data-service-select-meta class="mt-1 block text-xs text-slate-400">
            {helperText}
          </span>
        </span>
      </span>

      <span
        data-service-select-chevron
        class="relative ml-4 flex h-10 w-10 shrink-0 items-center justify-center rounded-full border border-white/10 bg-white/5 text-slate-200 transition-all duration-300 ease-refined"
      >
        <svg aria-hidden="true" viewBox="0 0 20 20" class="h-4 w-4">
          <path
            d="M5.25 7.75 10 12.25l4.75-4.5"
            fill="none"
            stroke="currentColor"
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="1.7"
          />
        </svg>
      </span>
    </button>

    <div
      id={listboxId}
      role="listbox"
      tabindex="-1"
      aria-hidden="true"
      data-service-select-panel
      class="service-select-panel absolute left-0 right-0 top-[calc(100%+0.75rem)] z-40 overflow-hidden rounded-[1.35rem] border border-cyan-200/20 bg-[linear-gradient(180deg,rgba(24,46,77,0.98),rgba(31,57,92,0.96))] p-2 shadow-[0_28px_70px_-32px_rgba(10,31,57,0.9),0_0_0_1px_rgba(173,233,255,0.12)] backdrop-blur-xl"
    >
      <div class="mb-2 flex items-center justify-between rounded-[1rem] border border-white/8 bg-white/[0.03] px-3 py-2">
        <span class="text-[11px] font-semibold uppercase tracking-[0.16em] text-cyan-100/80">Operational modules</span>
        <span class="text-[11px] text-slate-400">Select one</span>
      </div>

      <div class="max-h-[320px] space-y-1 overflow-y-auto pr-1">
        {
          options.map((option, index) => (
            <button
              type="button"
              role="option"
              data-service-option
              data-value={option.value}
              data-label={option.label}
              data-description={option.description ?? helperText}
              aria-selected="false"
              class="service-select-option flex w-full items-start gap-3 rounded-[1.125rem] border border-transparent px-4 py-3 text-left transition-all duration-300 ease-refined"
              style={`--option-index:${index};`}
            >
              <span class="mt-1.5 inline-flex h-2.5 w-2.5 shrink-0 rounded-full bg-gradient-to-br from-cyan-200 via-cyan-300 to-teal-200 shadow-[0_0_0_4px_rgba(76,204,243,0.08)]"></span>

              <span class="min-w-0 flex-1">
                <span class="flex flex-wrap items-center gap-2">
                  <span class="truncate text-sm font-semibold text-white">{option.label}</span>
                  {
                    option.signal && (
                      <span class="shrink-0 rounded-full border border-cyan-200/20 bg-cyan-300/10 px-2 py-1 text-[10px] font-semibold uppercase tracking-[0.12em] text-cyan-100">
                        {option.signal}
                      </span>
                    )
                  }
                </span>
                {
                  option.description && (
                    <span class="mt-1 block text-xs leading-relaxed text-slate-400">{option.description}</span>
                  )
                }
              </span>
            </button>
          ))
        }
      </div>
    </div>
  </div>

  <p data-error-for={name} class="mt-1 text-xs text-rose-300" hidden></p>
</div>

<script>
  const selectRoots = Array.from(document.querySelectorAll<HTMLElement>('[data-service-select]'));

  const getOptions = (root: HTMLElement): HTMLButtonElement[] =>
    Array.from(root.querySelectorAll<HTMLButtonElement>('[data-service-option]'));

  const setOpenState = (root: HTMLElement, open: boolean): void => {
    const trigger = root.querySelector<HTMLButtonElement>('[data-service-select-trigger]');
    const panel = root.querySelector<HTMLElement>('[data-service-select-panel]');
    const options = getOptions(root);

    root.dataset.open = open ? 'true' : 'false';
    trigger?.setAttribute('aria-expanded', open ? 'true' : 'false');
    panel?.setAttribute('aria-hidden', open ? 'false' : 'true');
    options.forEach((option) => {
      option.tabIndex = open ? 0 : -1;
    });
  };

  const closeAll = (except?: HTMLElement): void => {
    selectRoots.forEach((root) => {
      if (root === except) return;
      setOpenState(root, false);
    });
  };

  const syncSelectionState = (root: HTMLElement): void => {
    const input = root.querySelector<HTMLInputElement>('input[type="hidden"]');
    const label = root.querySelector<HTMLElement>('[data-service-select-label]');
    const meta = root.querySelector<HTMLElement>('[data-service-select-meta]');
    const options = getOptions(root);
    const placeholder = root.dataset.placeholder ?? 'Select an option';
    const helperText = root.dataset.helperText ?? '';
    const value = input?.value ?? '';
    const selectedOption = options.find((option) => option.dataset.value === value);

    options.forEach((option) => {
      option.setAttribute('aria-selected', option === selectedOption ? 'true' : 'false');
    });

    if (selectedOption) {
      root.dataset.hasValue = 'true';
      if (label) {
        label.textContent = selectedOption.dataset.label ?? placeholder;
      }
      if (meta) {
        meta.textContent = selectedOption.dataset.description ?? helperText;
      }
      return;
    }

    root.dataset.hasValue = 'false';
    if (label) {
      label.textContent = placeholder;
    }
    if (meta) {
      meta.textContent = helperText;
    }
  };

  const selectOption = (root: HTMLElement, option: HTMLButtonElement): void => {
    const input = root.querySelector<HTMLInputElement>('input[type="hidden"]');
    const trigger = root.querySelector<HTMLButtonElement>('[data-service-select-trigger]');

    if (!input) return;

    input.value = option.dataset.value ?? '';
    input.removeAttribute('aria-invalid');
    trigger?.removeAttribute('aria-invalid');
    syncSelectionState(root);
    input.dispatchEvent(new Event('input', { bubbles: true }));
    input.dispatchEvent(new Event('change', { bubbles: true }));
  };

  const focusOption = (root: HTMLElement, index: number): void => {
    const options = getOptions(root);
    if (options.length === 0) return;
    const nextIndex = (index + options.length) % options.length;
    options[nextIndex]?.focus();
  };

  selectRoots.forEach((root) => {
    if (root.dataset.bound === 'true') return;
    root.dataset.bound = 'true';

    const trigger = root.querySelector<HTMLButtonElement>('[data-service-select-trigger]');
    const form = root.closest('form');
    const options = getOptions(root);

    setOpenState(root, false);
    syncSelectionState(root);

    trigger?.addEventListener('click', () => {
      const isOpen = root.dataset.open === 'true';
      if (isOpen) {
        setOpenState(root, false);
        return;
      }

      closeAll(root);
      setOpenState(root, true);
    });

    trigger?.addEventListener('keydown', (event) => {
      if (event.key === 'ArrowDown') {
        event.preventDefault();
        closeAll(root);
        setOpenState(root, true);
        const selectedIndex = options.findIndex((option) => option.getAttribute('aria-selected') === 'true');
        focusOption(root, selectedIndex >= 0 ? selectedIndex : 0);
      }

      if (event.key === 'ArrowUp') {
        event.preventDefault();
        closeAll(root);
        setOpenState(root, true);
        const selectedIndex = options.findIndex((option) => option.getAttribute('aria-selected') === 'true');
        focusOption(root, selectedIndex >= 0 ? selectedIndex : options.length - 1);
      }

      if (event.key === 'Escape') {
        setOpenState(root, false);
      }
    });

    options.forEach((option, index) => {
      option.addEventListener('click', () => {
        selectOption(root, option);
        setOpenState(root, false);
        trigger?.focus();
      });

      option.addEventListener('keydown', (event) => {
        if (event.key === 'ArrowDown') {
          event.preventDefault();
          focusOption(root, index + 1);
        }

        if (event.key === 'ArrowUp') {
          event.preventDefault();
          focusOption(root, index - 1);
        }

        if (event.key === 'Home') {
          event.preventDefault();
          focusOption(root, 0);
        }

        if (event.key === 'End') {
          event.preventDefault();
          focusOption(root, options.length - 1);
        }

        if (event.key === 'Escape') {
          event.preventDefault();
          setOpenState(root, false);
          trigger?.focus();
        }

        if (event.key === 'Tab') {
          setOpenState(root, false);
        }
      });
    });

    document.addEventListener('pointerdown', (event) => {
      const target = event.target;
      if (!(target instanceof Node) || root.contains(target)) return;
      setOpenState(root, false);
    });

    form?.addEventListener('reset', () => {
      requestAnimationFrame(() => {
        setOpenState(root, false);
        syncSelectionState(root);
        trigger?.removeAttribute('aria-invalid');
      });
    });
  });
</script>

<style>
  .service-select-panel {
    opacity: 0;
    pointer-events: none;
    transform: translateY(10px) scale(0.98);
    transform-origin: top center;
    transition:
      opacity 220ms cubic-bezier(0.22, 1, 0.36, 1),
      transform 220ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  .service-select-option {
    opacity: 0;
    transform: translateY(-8px);
    background:
      linear-gradient(135deg, rgba(255, 255, 255, 0.04), transparent 58%),
      rgba(255, 255, 255, 0);
  }

  .service-select-root[data-open='true'] .service-select-trigger {
    border-color: rgba(167, 235, 255, 0.52);
    box-shadow:
      0 0 0 1px rgba(167, 235, 255, 0.2),
      0 18px 44px -26px rgba(68, 199, 242, 0.65),
      inset 0 1px 0 rgba(255, 255, 255, 0.1);
    transform: translateY(-1px);
  }

  .service-select-root[data-open='true'] .service-select-panel {
    opacity: 1;
    pointer-events: auto;
    transform: translateY(0) scale(1);
  }

  .service-select-root[data-open='true'] .service-select-option {
    opacity: 1;
    transform: translateY(0);
    transition:
      opacity 240ms cubic-bezier(0.22, 1, 0.36, 1),
      transform 240ms cubic-bezier(0.22, 1, 0.36, 1),
      border-color 220ms ease,
      background-color 220ms ease,
      box-shadow 220ms ease;
    transition-delay: calc(var(--option-index, 0) * 28ms);
  }

  .service-select-root[data-open='true'] [data-service-select-chevron] {
    transform: rotate(180deg);
    border-color: rgba(167, 235, 255, 0.24);
    background: rgba(167, 235, 255, 0.09);
    color: #def6ff;
  }

  .service-select-root[data-has-value='false'] [data-service-select-label] {
    color: rgba(248, 251, 255, 0.9);
  }

  .service-select-root[data-has-value='false'] [data-service-select-meta] {
    color: rgba(202, 217, 239, 0.76);
  }

  .service-select-trigger:hover {
    border-color: rgba(167, 235, 255, 0.35);
    box-shadow:
      0 14px 34px -24px rgba(68, 199, 242, 0.4),
      inset 0 1px 0 rgba(255, 255, 255, 0.1);
  }

  .service-select-trigger[aria-invalid='true'] {
    border-color: rgba(253, 164, 175, 0.7);
    box-shadow:
      0 0 0 1px rgba(253, 164, 175, 0.24),
      0 18px 42px -28px rgba(251, 113, 133, 0.4);
  }

  .service-select-option:hover,
  .service-select-option:focus-visible {
    border-color: rgba(167, 235, 255, 0.18);
    background:
      linear-gradient(135deg, rgba(167, 235, 255, 0.1), transparent 72%),
      rgba(255, 255, 255, 0.05);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.04);
    outline: none;
  }

  .service-select-option[aria-selected='true'] {
    border-color: rgba(167, 235, 255, 0.28);
    background:
      linear-gradient(135deg, rgba(167, 235, 255, 0.12), rgba(76, 204, 243, 0.03) 70%),
      rgba(255, 255, 255, 0.06);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.05),
      0 16px 36px -28px rgba(68, 199, 242, 0.45);
  }

  @media (prefers-reduced-motion: reduce) {
    .service-select-panel,
    .service-select-option,
    .service-select-trigger,
    [data-service-select-chevron] {
      transition: none !important;
      transform: none !important;
    }
  }
</style>
