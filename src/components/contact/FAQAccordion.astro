---
import type { FaqItem } from '@/types/content';

interface Props {
  items: FaqItem[];
}

const { items } = Astro.props as Props;
---

<section class="rounded-3xl border border-white/10 bg-white/10 p-6 md:p-8">
  <h2 class="text-2xl font-semibold text-white">Frequently asked questions</h2>
  <div class="mt-5 space-y-3">
    {
      items.map((item) => (
        <details class="group rounded-2xl border border-white/10 bg-white/10 p-4 open:border-cyan-300/40">
          <summary class="cursor-pointer list-none pr-8 text-sm font-semibold text-slate-100">{item.question}</summary>
          <p class="mt-3 text-sm text-slate-300">{item.answer}</p>
        </details>
      ))
    }
  </div>
</section>


