---
import type { FaqItem } from '@/types/content';

interface Props {
  items: FaqItem[];
}

const { items } = Astro.props as Props;
---

<section class="rounded-3xl border border-white/10 bg-white/10 p-6 md:p-8">
  <h2 class="text-2xl font-semibold text-white">Frequently asked questions</h2>
  <div class="mt-5 space-y-3">
    {
      items.map((item) => (
        <details class="faq-item group rounded-2xl border border-white/10 bg-white/10 p-4 transition-all duration-300 ease-refined open:border-cyan-300/40 open:bg-white/12">
          <summary class="faq-trigger flex w-full cursor-pointer list-none items-center justify-between gap-4 pr-1 text-sm font-semibold text-slate-100">
            <span class="max-w-[85%]">{item.question}</span>
            <span class="faq-icon inline-flex h-9 w-9 shrink-0 items-center justify-center rounded-full border border-white/10 bg-white/5 text-slate-200 transition-all duration-300 ease-refined">
              <svg aria-hidden="true" viewBox="0 0 20 20" class="h-4 w-4">
                <path
                  d="M5.25 7.75 10 12.25l4.75-4.5"
                  fill="none"
                  stroke="currentColor"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="1.7"
                />
              </svg>
            </span>
          </summary>
          <p class="mt-3 pr-10 text-sm text-slate-300">{item.answer}</p>
        </details>
      ))
    }
  </div>
</section>

<style>
  .faq-item {
    transform-origin: center;
  }

  .faq-item:hover {
    cursor: pointer;
    transform: translateY(-2px) scale(1.015);
    border-color: rgba(167, 235, 255, 0.28);
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.14), rgba(255, 255, 255, 0.1));
    box-shadow:
      0 18px 42px -30px rgba(68, 199, 242, 0.45),
      inset 0 1px 0 rgba(255, 255, 255, 0.06);
  }

  .faq-trigger::-webkit-details-marker {
    display: none;
  }

  .faq-item:hover .faq-icon,
  .faq-trigger:focus-visible .faq-icon {
    border-color: rgba(167, 235, 255, 0.28);
    background: rgba(167, 235, 255, 0.1);
    color: #def6ff;
  }

  .faq-item[open] .faq-icon {
    transform: rotate(180deg);
    border-color: rgba(167, 235, 255, 0.28);
    background: rgba(167, 235, 255, 0.12);
    color: #def6ff;
  }

  .faq-trigger:focus-visible {
    outline: none;
  }

  @media (prefers-reduced-motion: reduce) {
    .faq-item,
    .faq-icon {
      transition: none !important;
      transform: none !important;
    }
  }
</style>
