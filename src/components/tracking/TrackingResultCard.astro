---
import type { ShipmentStatus, TrackingRecord } from '@/types/tracking';
import { formatDate } from '@/lib/utils/formatDate';
import TrackingTimeline from './TrackingTimeline.astro';

interface Props {
  mode?: 'preview' | 'full';
  record?: TrackingRecord | null;
}

const { mode = 'preview', record = null } = Astro.props as Props;
const isFull = mode === 'full';

const STATUS_CLASS_MAP: Record<ShipmentStatus, string> = {
  'Label Created': 'border-slate-300/40 bg-slate-400/10 text-slate-100',
  'Picked Up': 'border-sky-300/40 bg-sky-300/10 text-sky-100',
  'In Transit': 'border-cyan-300/40 bg-cyan-300/10 text-cyan-100',
  'Arrived at Hub': 'border-indigo-300/40 bg-indigo-300/10 text-indigo-100',
  'Out for Delivery': 'border-teal-300/40 bg-teal-300/10 text-teal-100',
  Delivered: 'border-emerald-300/40 bg-emerald-300/10 text-emerald-100',
  Delayed: 'border-amber-300/40 bg-amber-300/10 text-amber-100',
};

const statusBadgeClass = record
  ? STATUS_CLASS_MAP[record.status]
  : 'border-slate-300/40 bg-slate-400/10 text-slate-100';
---

<article data-tracking-result hidden={!record} class="mt-6 rounded-2xl border border-white/15 bg-white/15 p-5 md:p-6">
  <div class="flex flex-wrap items-start justify-between gap-3 border-b border-white/10 pb-4">
    <div>
      <p class="text-xs uppercase tracking-[0.1em] text-slate-400">Shipment status</p>
      <h3 class="mt-1 text-lg font-semibold text-white" data-field="id">{record?.id ?? '-'}</h3>
    </div>
    <span
      data-status-badge
      class={`inline-flex items-center rounded-full border px-3 py-1 text-xs font-semibold uppercase tracking-[0.1em] ${statusBadgeClass}`}
    >
      {record?.status ?? 'Status'}
    </span>
  </div>

  <div class="mt-4 grid gap-3 text-sm sm:grid-cols-2">
    <div class="rounded-xl border border-white/10 bg-white/10 p-3">
      <p class="text-xs uppercase tracking-[0.1em] text-slate-400">Route</p>
      <p class="mt-1 text-slate-100" data-field="route">{record?.route ?? '-'}</p>
    </div>
    <div class="rounded-xl border border-white/10 bg-white/10 p-3">
      <p class="text-xs uppercase tracking-[0.1em] text-slate-400">Estimated arrival</p>
      <p class="mt-1 text-slate-100" data-field="estimatedArrival">{record ? formatDate(record.estimatedArrival) : '-'}</p>
    </div>
    <div class="rounded-xl border border-white/10 bg-white/10 p-3">
      <p class="text-xs uppercase tracking-[0.1em] text-slate-400">Current hub</p>
      <p class="mt-1 text-slate-100" data-field="currentLocation">{record?.currentLocation ?? '-'}</p>
    </div>
    <div class="rounded-xl border border-white/10 bg-white/10 p-3">
      <p class="text-xs uppercase tracking-[0.1em] text-slate-400">Shipment type</p>
      <p class="mt-1 text-slate-100" data-field="shipmentType">{record?.shipmentType ?? '-'}</p>
    </div>
  </div>

  {
    isFull && (
      <>
        <div class="mt-4 grid gap-3 text-sm sm:grid-cols-2">
          <div class="rounded-xl border border-white/10 bg-white/10 p-3">
            <p class="text-xs uppercase tracking-[0.1em] text-slate-400">Origin</p>
            <p class="mt-1 text-slate-100" data-field="origin">{record?.origin ?? '-'}</p>
          </div>
          <div class="rounded-xl border border-white/10 bg-white/10 p-3">
            <p class="text-xs uppercase tracking-[0.1em] text-slate-400">Destination</p>
            <p class="mt-1 text-slate-100" data-field="destination">{record?.destination ?? '-'}</p>
          </div>
          <div class="rounded-xl border border-white/10 bg-white/10 p-3">
            <p class="text-xs uppercase tracking-[0.1em] text-slate-400">Last update</p>
            <p class="mt-1 text-slate-100" data-field="lastUpdate">{record ? formatDate(record.lastUpdate) : '-'}</p>
          </div>
          <div class="rounded-xl border border-white/10 bg-white/10 p-3">
            <p class="text-xs uppercase tracking-[0.1em] text-slate-400">Service level</p>
            <p class="mt-1 text-slate-100" data-field="serviceLevel">{record?.serviceLevel ?? '-'}</p>
          </div>
        </div>

        <p
          data-support-note-wrapper
          class="mt-4 rounded-xl border border-amber-300/30 bg-amber-300/10 px-4 py-3 text-sm text-amber-100"
          hidden={!record?.supportNote}
        >
          <span class="font-semibold">Support note:</span>
          <span data-field="supportNote">{record?.supportNote ?? ''}</span>
        </p>

        <TrackingTimeline events={record?.timeline ?? []} />
      </>
    )
  }
</article>


