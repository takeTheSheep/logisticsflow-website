---
import SystemIcon from '@/components/common/SystemIcon.astro';
import type { TrackingEvent } from '@/types/tracking';
import { formatDate } from '@/lib/utils/formatDate';

interface Props {
  events?: TrackingEvent[];
}

const { events = [] } = Astro.props as Props;

const statusIconMap = {
  'Label Created': 'dashboard',
  'Picked Up': 'box',
  'In Transit': 'route',
  'Arrived at Hub': 'warehouse',
  'Out for Delivery': 'monitoring',
  Delivered: 'visibility',
  Delayed: 'support',
} as const;
---

<section aria-label="Shipment timeline" class="mt-6">
  <div class="mb-3 flex items-center justify-between">
    <h3 class="text-sm font-semibold uppercase tracking-[0.1em] text-cyan-100/90">Shipment Timeline</h3>
    <span class="rounded-full border border-white/20 bg-white/15 px-2.5 py-1 text-[11px] font-semibold uppercase tracking-[0.12em] text-slate-100">
      Progress View
    </span>
  </div>

  <ol data-timeline class="mt-4 space-y-3">
    {
      events.map((event, index) => {
        const isLatest = index === events.length - 1;
        const iconName = statusIconMap[event.status] ?? 'monitoring';

        return (
          <li class={`relative rounded-xl border bg-white/10 p-3 pl-12 ${isLatest ? 'border-cyan-200/55' : 'border-white/10'}`}>
            <span class="absolute left-4 top-4 inline-flex items-center justify-center">
              <SystemIcon
                name={iconName}
                size="sm"
                class={isLatest ? 'border-cyan-200/60 bg-cyan-200/25 animate-pulse' : ''}
              />
            </span>
            {index < events.length - 1 && (
              <span class="absolute left-[1.45rem] top-10 h-[calc(100%+0.55rem)] w-px bg-cyan-200/30"></span>
            )}
            <div class="flex flex-wrap items-center justify-between gap-2">
              <p class="text-sm font-semibold text-white">{event.status}</p>
              <p class="text-xs text-slate-200">{formatDate(event.timestamp)}</p>
            </div>
            <p class="mt-1 text-xs text-slate-300">{event.location}</p>
            {event.note && <p class="mt-1 text-xs text-amber-100">{event.note}</p>}
          </li>
        );
      })
    }
  </ol>
</section>
