---
import { demoTrackingCodes } from '@/data/trackingDemo';
import type { TrackingRecord } from '@/types/tracking';
import TrackingResultCard from './TrackingResultCard.astro';

interface Props {
  mode?: 'preview' | 'full';
  title?: string;
  description?: string;
  action?: string;
  initialCode?: string;
  initialError?: string;
  initialRecord?: TrackingRecord | null;
}

const {
  mode = 'preview',
  title = 'Track a shipment',
  description = 'Enter a LogisticsFlow demo tracking ID to see live shipment context.',
  action = '/tracking',
  initialCode = '',
  initialError = '',
  initialRecord = null,
} = Astro.props as Props;

const showEmptyState = !initialRecord && !initialError;
---

<div data-tracking-widget data-mode={mode} class="panel border-white/15 bg-white/15 p-5 md:p-6">
  <h3 class="text-2xl font-semibold text-white">{title}</h3>
  <p class="mt-2 text-sm text-slate-300 md:text-base">{description}</p>

  <form data-tracking-form class="mt-5" method="get" action={action} novalidate>
    <label for={`tracking-${mode}`} class="mb-2 block text-sm font-medium text-slate-100">Tracking ID</label>
    <div class="flex flex-col gap-3 sm:flex-row">
      <input
        id={`tracking-${mode}`}
        name="trackingCode"
        type="text"
        inputmode="text"
        autocomplete="off"
        placeholder="LF-48291"
        value={initialCode}
        class="h-12 w-full rounded-xl border border-white/15 bg-white/10 px-4 text-sm text-white placeholder:text-slate-500 transition-all duration-200 focus:border-cyan-300/70 focus:ring-2 focus:ring-cyan-300/30"
        maxlength="8"
        required
        aria-describedby={`tracking-error-${mode}`}
      />
      <button
        type="submit"
        data-tracking-submit
        data-ripple
        aria-label="Check shipment status"
        class="inline-flex h-11 items-center justify-center rounded-xl bg-gradient-to-r from-sky-200 via-cyan-200 to-teal-200 px-5 text-sm font-semibold tracking-tight text-ink-900 shadow-[0_12px_30px_-20px_rgba(102,195,235,0.85),0_0_0_1px_rgba(225,247,255,0.8)] transition-all duration-300 ease-refined hover:-translate-y-0.5 hover:brightness-105 hover:shadow-glow focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-cyan-200 focus-visible:ring-offset-2 focus-visible:ring-offset-ink-900 sm:min-w-[148px] md:text-base"
      >
        Check Status
      </button>
    </div>
    <p id={`tracking-error-${mode}`} data-tracking-error class="mt-2 text-sm text-rose-300" hidden={!initialError}>
      {initialError}
    </p>

    <div class="mt-4 flex flex-wrap items-center gap-2 text-xs text-slate-400">
      <span class="uppercase tracking-[0.1em] text-slate-500">Try demo IDs:</span>
      {
        demoTrackingCodes.map((code) => (
          <button
            type="button"
            data-demo-code={code}
            data-ripple
            class="rounded-full border border-white/15 bg-white/5 px-3 py-1 font-semibold text-slate-200 transition-colors hover:border-cyan-300/45 hover:text-cyan-100"
          >
            {code}
          </button>
        ))
      }
    </div>
  </form>

  <p data-tracking-empty class="mt-5 text-sm text-slate-400" hidden={!showEmptyState}>
    Shipment details will appear below after validation.
  </p>

  <TrackingResultCard mode={mode} record={initialRecord} />
</div>

<script>
  import { getTrackingRecord } from '@/lib/tracking/getTrackingRecord';
  import { normalizeTrackingCode, validateTrackingCode } from '@/lib/tracking/validateTrackingCode';
  import { formatDate } from '@/lib/utils/formatDate';
  import type { ShipmentStatus, TrackingEvent, TrackingRecord } from '@/types/tracking';

  const STATUS_CLASS_MAP: Record<ShipmentStatus, string> = {
    'Label Created': 'border-slate-300/40 bg-slate-400/10 text-slate-100',
    'Picked Up': 'border-sky-300/40 bg-sky-300/10 text-sky-100',
    'In Transit': 'border-cyan-300/40 bg-cyan-300/10 text-cyan-100',
    'Arrived at Hub': 'border-indigo-300/40 bg-indigo-300/10 text-indigo-100',
    'Out for Delivery': 'border-teal-300/40 bg-teal-300/10 text-teal-100',
    Delivered: 'border-emerald-300/40 bg-emerald-300/10 text-emerald-100',
    Delayed: 'border-amber-300/40 bg-amber-300/10 text-amber-100',
  };

  const STATUS_BADGE_BASE_CLASS =
    'inline-flex items-center rounded-full border px-3 py-1 text-xs font-semibold uppercase tracking-[0.1em]';

  const widgets = document.querySelectorAll<HTMLElement>('[data-tracking-widget]');

  const createTimelineItem = (event: TrackingEvent, isLast: boolean): HTMLLIElement => {
    const item = document.createElement('li');
    item.className = 'relative rounded-xl border border-white/10 bg-white/10 p-3 pl-10';

    const marker = document.createElement('span');
    marker.className = 'absolute left-4 top-4 inline-flex h-2.5 w-2.5 rounded-full bg-cyan-300';
    item.appendChild(marker);

    if (!isLast) {
      const connector = document.createElement('span');
      connector.className = 'absolute left-[1.12rem] top-7 h-[calc(100%+0.6rem)] w-px bg-cyan-300/30';
      item.appendChild(connector);
    }

    const status = document.createElement('p');
    status.className = 'text-sm font-semibold text-white';
    status.textContent = event.status;
    item.appendChild(status);

    const meta = document.createElement('p');
    meta.className = 'mt-1 text-xs text-slate-300';
    meta.textContent = `${event.location} - ${formatDate(event.timestamp)}`;
    item.appendChild(meta);

    if (event.note) {
      const note = document.createElement('p');
      note.className = 'mt-1 text-xs text-amber-100';
      note.textContent = event.note;
      item.appendChild(note);
    }

    return item;
  };

  widgets.forEach((widget) => {
    const form = widget.querySelector<HTMLFormElement>('[data-tracking-form]');
    const input = widget.querySelector<HTMLInputElement>('input[name="trackingCode"]');
    const submitButton = widget.querySelector<HTMLButtonElement>('[data-tracking-submit], button[type="submit"]');
    const errorBox = widget.querySelector<HTMLParagraphElement>('[data-tracking-error]');
    const emptyState = widget.querySelector<HTMLParagraphElement>('[data-tracking-empty]');
    const resultCard = widget.querySelector<HTMLElement>('[data-tracking-result]');
    const badge = widget.querySelector<HTMLElement>('[data-status-badge]');
    const timeline = widget.querySelector<HTMLOListElement>('[data-timeline]');
    const noteWrapper = widget.querySelector<HTMLElement>('[data-support-note-wrapper]');
    const sampleButtons = widget.querySelectorAll<HTMLButtonElement>('[data-demo-code]');

    if (!form || !input || !submitButton || !errorBox || !emptyState || !resultCard || !badge) {
      return;
    }

    if (form.dataset.bound === 'true') {
      return;
    }
    form.dataset.bound = 'true';

    const isFullTrackingPage = widget.getAttribute('data-mode') === 'full';
    const defaultSubmitLabel = submitButton.textContent?.trim() || 'Check Status';

    const setField = (field: string, value: string): void => {
      const element = resultCard.querySelector<HTMLElement>(`[data-field="${field}"]`);
      if (element) {
        element.textContent = value;
      }
    };

    const clearError = (): void => {
      errorBox.textContent = '';
      errorBox.setAttribute('hidden', 'true');
      input.setAttribute('aria-invalid', 'false');
    };

    const setError = (message: string): void => {
      errorBox.textContent = message;
      errorBox.removeAttribute('hidden');
      input.setAttribute('aria-invalid', 'true');
      resultCard.setAttribute('hidden', 'true');
      emptyState.removeAttribute('hidden');
    };

    const setLoading = (loading: boolean): void => {
      submitButton.toggleAttribute('disabled', loading);
      submitButton.textContent = loading ? 'Checking...' : defaultSubmitLabel;
    };

    const renderTimeline = (events: TrackingEvent[]): void => {
      if (!timeline) return;

      timeline.innerHTML = '';
      events.forEach((event, index) => {
        timeline.appendChild(createTimelineItem(event, index === events.length - 1));
      });
    };

    const renderResult = (record: TrackingRecord): void => {
      setField('id', record.id);
      setField('route', record.route);
      setField('estimatedArrival', formatDate(record.estimatedArrival));
      setField('currentLocation', record.currentLocation);
      setField('shipmentType', record.shipmentType);

      setField('origin', record.origin);
      setField('destination', record.destination);
      setField('lastUpdate', formatDate(record.lastUpdate));
      setField('serviceLevel', record.serviceLevel);
      setField('supportNote', record.supportNote ?? '');

      badge.textContent = record.status;
      badge.className = `${STATUS_BADGE_BASE_CLASS} ${STATUS_CLASS_MAP[record.status] ?? STATUS_CLASS_MAP['In Transit']}`;

      if (noteWrapper) {
        if (record.supportNote) {
          noteWrapper.removeAttribute('hidden');
        } else {
          noteWrapper.setAttribute('hidden', 'true');
        }
      }

      renderTimeline(record.timeline);
      resultCard.removeAttribute('hidden');
      emptyState.setAttribute('hidden', 'true');
      clearError();
    };

    const processTrackingCode = (rawCode: string): void => {
      const normalizedCode = normalizeTrackingCode(rawCode);
      input.value = normalizedCode;

      if (!validateTrackingCode(normalizedCode)) {
        setError('Enter a valid tracking code format like LF-48291.');
        return;
      }

      const record = getTrackingRecord(normalizedCode);
      if (!record) {
        setError('Tracking code not found in demo records. Try one of the sample codes.');
        return;
      }

      renderResult(record);
    };

    const syncTrackingCodeInUrl = (rawCode: string): void => {
      if (!isFullTrackingPage) return;
      const normalizedCode = normalizeTrackingCode(rawCode);

      try {
        const url = new URL(window.location.href);

        if (normalizedCode) {
          url.searchParams.set('trackingCode', normalizedCode);
        } else {
          url.searchParams.delete('trackingCode');
        }

        history.replaceState(null, '', `${url.pathname}${url.search}`);
      } catch {
        // Ignore URL sync errors (e.g., restrictive local file contexts).
      }
    };

    const handleSubmit = async (event: SubmitEvent): Promise<void> => {
      event.preventDefault();
      clearError();
      setLoading(true);

      try {
        processTrackingCode(input.value);
        syncTrackingCodeInUrl(input.value);
      } catch {
        setError('Could not process tracking right now. Please try again.');
      } finally {
        setLoading(false);
      }
    };

    form.addEventListener('submit', handleSubmit);

    if (isFullTrackingPage) {
      const urlCode = new URLSearchParams(window.location.search).get('trackingCode');
      if (urlCode) {
        processTrackingCode(urlCode);
      }
    }

    sampleButtons.forEach((button) => {
      button.addEventListener('click', () => {
        const code = button.getAttribute('data-demo-code') ?? '';
        input.value = code;
        input.focus();
        clearError();
      });
    });

    input.addEventListener('input', () => {
      if (errorBox.hasAttribute('hidden')) return;
      clearError();
    });
  });
</script>


