---
import type { IconKey } from '@/types/content';
import { cn } from '@/lib/utils/cn';

interface Props {
  name: IconKey;
  size?: 'sm' | 'md' | 'lg';
  class?: string;
}

const { name, size = 'md', class: className = '' } = Astro.props as Props;

const sizeClass = {
  sm: 'h-4 w-4',
  md: 'h-5 w-5',
  lg: 'h-6 w-6',
}[size];

const iconPaths: Record<IconKey, string> = {
  box: '<path d="M4 7.5 12 3l8 4.5v9L12 21l-8-4.5v-9Z"/><path d="M4 7.5 12 12l8-4.5"/><path d="M12 12v9"/>',
  warehouse: '<path d="M3 10 12 4l9 6v10H3V10Z"/><path d="M8 20v-6h8v6"/><path d="M8 10h.01M12 10h.01M16 10h.01"/>',
  route: '<path d="M5 6h5v5H5z"/><circle cx="18" cy="18" r="3"/><path d="M10 8h4a4 4 0 0 1 4 4v3"/>',
  visibility: '<path d="M2 12s3.5-6 10-6 10 6 10 6-3.5 6-10 6S2 12 2 12Z"/><circle cx="12" cy="12" r="3"/>',
  support: '<circle cx="12" cy="12" r="9"/><path d="M9.5 9a2.5 2.5 0 0 1 5 0c0 2-2.5 2-2.5 4"/><path d="M12 17h.01"/>',
  border: '<path d="M4 4h16v16H4z"/><path d="M4 10h16M10 4v16"/>',
  astro: '<path d="m12 3 2.5 6.3L21 12l-6.5 2.7L12 21l-2.5-6.3L3 12l6.5-2.7L12 3Z"/><path d="M9 13c1.2 2 4.8 2 6 0"/>',
  typescript: '<path d="M4 4h16v16H4z"/><path d="M8 9h8M12 9v8"/><path d="M8 17h4"/>',
  tailwind: '<path d="M4 10c2-4 6-4 8 0 2 4 6 4 8 0"/><path d="M4 16c2-4 6-4 8 0 2 4 6 4 8 0"/>',
  components: '<rect x="3" y="4" width="8" height="7" rx="1"/><rect x="13" y="4" width="8" height="7" rx="1"/><rect x="8" y="13" width="8" height="7" rx="1"/>',
  static: '<path d="M4 19h16"/><path d="M7 19V8l5-4 5 4v11"/><path d="M12 10v3"/>',
  performance: '<path d="M4 14a8 8 0 1 1 16 0"/><path d="m12 12 5-2"/><circle cx="12" cy="12" r="1"/>',
  seo: '<path d="M4 5h16v14H4z"/><path d="M8 9h8M8 13h5"/><circle cx="17" cy="16" r="2"/>',
  dashboard: '<rect x="3" y="4" width="18" height="16" rx="2"/><path d="M7 9h4M7 13h7M7 17h3M14 17h3"/>',
  api: '<path d="M8 7h8v10H8z"/><path d="M4 12h2M18 12h2M12 4v2M12 18v2"/>',
  monitoring: '<path d="M4 15h4l2-4 3 6 2-4h5"/><path d="M4 6h16v12H4z"/>',
  frontend: '<path d="M3 5h18v14H3z"/><path d="M3 9h18"/><path d="M8 13h3M13 13h3"/>',
  engine: '<circle cx="12" cy="12" r="3"/><path d="M12 4v3M12 17v3M4 12h3M17 12h3M6.3 6.3l2.1 2.1M15.6 15.6l2.1 2.1M17.7 6.3l-2.1 2.1M8.4 15.6l-2.1 2.1"/>',
  data: '<ellipse cx="12" cy="6" rx="7" ry="3"/><path d="M5 6v8c0 1.7 3.1 3 7 3s7-1.3 7-3V6"/><path d="M5 10c0 1.7 3.1 3 7 3s7-1.3 7-3"/>',
  integration: '<path d="M8 7h4v4H8zM12 13h4v4h-4z"/><path d="M12 9h4a2 2 0 0 1 2 2v2"/><path d="M12 15H8a2 2 0 0 1-2-2v-2"/>',
  notification: '<path d="M18 16H6l1.2-2.1A7 7 0 0 0 8 10.5V9a4 4 0 1 1 8 0v1.5a7 7 0 0 0 .8 3.4L18 16Z"/><path d="M10 18a2 2 0 0 0 4 0"/>',
  analytics: '<path d="M4 20V8"/><path d="M10 20V4"/><path d="M16 20v-9"/><path d="M22 20V11"/>',
  workflow: '<circle cx="4" cy="12" r="2"/><circle cx="12" cy="6" r="2"/><circle cx="12" cy="18" r="2"/><circle cx="20" cy="12" r="2"/><path d="M6 12h4M12 8v4M12 16v-4M14 12h4"/>',
  request: '<path d="M5 4h12l2 2v14H5V4Z"/><path d="M17 4v4h4"/><path d="M8 11h8M8 15h6"/>',
};

const iconMarkup = iconPaths[name];
---

<span class={cn('inline-flex items-center justify-center rounded-lg border border-white/25 bg-white/15 text-cyan-50', sizeClass, className)}>
  <svg
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="1.7"
    stroke-linecap="round"
    stroke-linejoin="round"
    class="h-[70%] w-[70%]"
    set:html={iconMarkup}
    aria-hidden="true"
  ></svg>
</span>
