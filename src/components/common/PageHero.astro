---
import Container from '@/components/common/Container.astro';
import Badge from '@/components/common/Badge.astro';

interface Props {
  eyebrow?: string;
  title: string;
  description: string;
}

const { eyebrow, title, description } = Astro.props as Props;
---

<section class="section-spacing pt-32 md:pt-36">
  <Container>
    <div class="rounded-3xl border border-white/20 bg-gradient-to-br from-white/20 to-white/10 p-8 md:p-12 shadow-card backdrop-blur-sm">
      {eyebrow && (
        <div class="mb-4">
          <Badge text={eyebrow} />
        </div>
      )}
      <h1 class="max-w-4xl text-4xl font-bold leading-tight text-white md:text-5xl">{title}</h1>
      <p class="mt-5 max-w-3xl text-base text-slate-300 md:text-lg">{description}</p>
    </div>
  </Container>
</section>

