---
import Button from './Button.astro';
import SystemIcon from './SystemIcon.astro';
import type { IconKey } from '@/types/content';

interface Props {
  title: string;
  summary: string;
  href: string;
  icon: IconKey;
  signal: string;
}

const { title, summary, href, icon, signal } = Astro.props as Props;
---

<article
  class="panel group flex h-full flex-col justify-between border-white/10 transition-all duration-300 hover:-translate-y-1 hover:border-cyan-300/50 hover:shadow-glow"
  data-reveal
>
  <div>
    <div class="mb-4 flex items-center justify-between">
      <SystemIcon name={icon} />
      <span class="rounded-full border border-cyan-200/45 bg-cyan-200/20 px-2.5 py-1 text-[11px] font-semibold uppercase tracking-[0.12em] text-cyan-50">
        {signal}
      </span>
    </div>
    <h3 class="text-xl font-semibold text-white">{title}</h3>
    <p class="mt-3 text-sm text-slate-300">{summary}</p>
  </div>
  <div class="mt-6 flex items-center justify-between">
    <span class="h-1 w-16 rounded-full bg-gradient-to-r from-cyan-200/80 to-transparent"></span>
    <Button href={href} variant="ghost" class="p-0 text-cyan-200 group-hover:text-cyan-100">
      Explore service
      <span aria-hidden="true" class="ml-2 transition-transform duration-300 group-hover:translate-x-1">-></span>
    </Button>
  </div>
</article>
