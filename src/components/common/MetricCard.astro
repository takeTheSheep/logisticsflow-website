---
interface Props {
  value: string;
  label: string;
  detail: string;
}

const { value, label, detail } = Astro.props as Props;
---

<article class="panel transition-all duration-300 hover:-translate-y-1 hover:border-cyan-300/40 hover:shadow-glow">
  <p class="text-3xl font-bold text-white">{value}</p>
  <h3 class="mt-2 text-sm font-semibold uppercase tracking-[0.1em] text-cyan-200/90">{label}</h3>
  <p class="mt-3 text-sm text-slate-300">{detail}</p>
</article>
