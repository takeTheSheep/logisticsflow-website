---
import Container from './Container.astro';
import Badge from './Badge.astro';

interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
  align?: 'left' | 'center';
  class?: string;
}

const {
  eyebrow,
  title,
  description,
  align = 'left',
  class: className = '',
} = Astro.props as Props;

const alignment = align === 'center' ? 'mx-auto max-w-3xl text-center' : 'max-w-3xl text-left';
---

<Container class={className}>
  <div class={alignment}>
    {eyebrow && (
      <div class="mb-4">
        <Badge text={eyebrow} />
      </div>
    )}
    <h2 class="text-3xl font-bold leading-tight text-white md:text-4xl">{title}</h2>
    {description && <p class="mt-4 text-base text-slate-300 md:text-lg">{description}</p>}
  </div>
</Container>
