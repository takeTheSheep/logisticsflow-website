---
interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props as Props;
---

<article class="panel h-full border-white/10 transition-all duration-300 hover:border-cyan-300/50 hover:bg-white/15">
  <h3 class="text-xl font-semibold text-white">{title}</h3>
  <p class="mt-3 text-sm text-slate-300">{description}</p>
</article>


