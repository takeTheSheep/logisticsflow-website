---
import { cn } from '@/lib/utils/cn';

interface Props {
  href?: string;
  variant?: 'primary' | 'secondary' | 'ghost';
  size?: 'sm' | 'md' | 'lg';
  type?: 'button' | 'submit' | 'reset';
  class?: string;
  ariaLabel?: string;
  target?: '_blank' | '_self' | '_parent' | '_top';
  rel?: string;
  id?: string;
}

const {
  href,
  variant = 'primary',
  size = 'md',
  type = 'button',
  class: className = '',
  ariaLabel,
  target,
  rel,
  id,
  ...rest
} = Astro.props as Props & Record<string, unknown>;

const baseClass =
  'relative isolate inline-flex items-center justify-center overflow-hidden rounded-xl font-semibold tracking-tight transition-all duration-300 ease-refined focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-cyan-300 focus-visible:ring-offset-2 focus-visible:ring-offset-ink-900';

const sizeClass = {
  sm: 'h-10 px-4 text-sm',
  md: 'h-11 px-5 text-sm md:text-base',
  lg: 'h-12 px-6 text-base',
}[size];

const variantClass = {
  primary:
    'bg-gradient-to-r from-sky-200 via-cyan-200 to-teal-200 text-ink-900 shadow-[0_12px_30px_-20px_rgba(102,195,235,0.85),0_0_0_1px_rgba(225,247,255,0.8)] hover:-translate-y-0.5 hover:brightness-105 hover:shadow-glow',
  secondary:
    'border border-white/35 bg-white/15 text-white hover:-translate-y-0.5 hover:border-white/55 hover:bg-white/25',
  ghost: 'text-slate-100 hover:bg-white/15 hover:text-white',
}[variant];

const classes = cn(baseClass, sizeClass, variantClass, className);
---

{
  href ? (
    <a href={href} class={classes} aria-label={ariaLabel} target={target} rel={rel} id={id} data-ripple {...rest}>
      <slot />
    </a>
  ) : (
    <button type={type} class={classes} aria-label={ariaLabel} id={id} data-ripple {...rest}>
      <slot />
    </button>
  )
}


