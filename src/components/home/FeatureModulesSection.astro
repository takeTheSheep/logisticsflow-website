---
import Container from '@/components/common/Container.astro';
import SectionHeading from '@/components/common/SectionHeading.astro';
import SystemIcon from '@/components/common/SystemIcon.astro';
import { featureModules } from '@/data/platform';
---

<section class="section-spacing pt-4" id="feature-modules">
  <SectionHeading
    eyebrow="Feature Modules"
    title="Core logistics modules in the platform"
    description="A modular architecture grid showing how each subsystem contributes to operational execution."
  />

  <Container class="mt-10">
    <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-3">
      {
        featureModules.map((module, index) => (
          <article
            class="panel group border-white/15 transition-all duration-300 hover:-translate-y-1 hover:border-cyan-300/45 hover:shadow-glow"
            data-reveal
            style={`transition-delay: ${index * 55}ms`}
          >
            <div class="mb-4 flex items-center gap-3">
              <SystemIcon name={module.icon} />
              <h3 class="text-lg font-semibold text-white">{module.title}</h3>
            </div>
            <p class="text-sm text-slate-300">{module.description}</p>

            <ul class="mt-4 space-y-1 overflow-hidden text-xs text-slate-200 opacity-0 transition-all duration-300 group-hover:max-h-28 group-hover:opacity-100 max-h-0">
              {module.handles.map((item) => <li class="flex items-start gap-2"><span class="mt-1 h-1.5 w-1.5 rounded-full bg-cyan-200"></span><span>{item}</span></li>)}
            </ul>
          </article>
        ))
      }
    </div>
  </Container>
</section>
