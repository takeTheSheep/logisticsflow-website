---
import Container from '@/components/common/Container.astro';
import SectionHeading from '@/components/common/SectionHeading.astro';
import SystemIcon from '@/components/common/SystemIcon.astro';
import { developerFeatures } from '@/data/platform';
---

<section class="section-spacing pt-4" id="developer-features">
  <SectionHeading
    eyebrow="Developer Friendly"
    title="Engineering qualities behind the demo"
    description="This portfolio project is structured to demonstrate architecture quality, integration readiness, and maintainable systems design."
  />

  <Container class="mt-10">
    <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-5">
      {
        developerFeatures.map((item, index) => (
          <article
            class="panel border-white/15 transition-all duration-300 hover:-translate-y-1 hover:border-cyan-300/45 hover:shadow-glow"
            data-reveal
            style={`transition-delay:${index * 45}ms`}
          >
            <div class="mb-3 flex items-center gap-3">
              <SystemIcon name={item.icon} />
              <h3 class="text-sm font-semibold text-white">{item.title}</h3>
            </div>
            <p class="text-xs text-slate-300">{item.description}</p>
          </article>
        ))
      }
    </div>
  </Container>
</section>
