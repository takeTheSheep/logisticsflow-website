---
import Container from '@/components/common/Container.astro';
import SectionHeading from '@/components/common/SectionHeading.astro';
import {
  deliverySuccessRate,
  monthlyShipmentsSeries,
  routeEfficiencyBars,
  shipmentTypeSlices,
} from '@/data/platform';

const chartWidth = 360;
const chartHeight = 180;
const chartPadding = 20;

const maxValue = Math.max(...monthlyShipmentsSeries.map((point) => point.value));
const minValue = Math.min(...monthlyShipmentsSeries.map((point) => point.value));

const linePoints = monthlyShipmentsSeries.map((point, index) => {
  const x = chartPadding + (index * (chartWidth - chartPadding * 2)) / (monthlyShipmentsSeries.length - 1);
  const ratio = (point.value - minValue) / (maxValue - minValue || 1);
  const y = chartHeight - chartPadding - ratio * (chartHeight - chartPadding * 2);
  return { ...point, x, y };
});

const linePath = linePoints.map((point) => `${point.x},${point.y}`).join(' ');
const areaPath = `M ${linePoints[0].x} ${chartHeight - chartPadding} L ${linePoints
  .map((point) => `${point.x} ${point.y}`)
  .join(' L ')} L ${linePoints[linePoints.length - 1].x} ${chartHeight - chartPadding} Z`;

const totalPie = shipmentTypeSlices.reduce((sum, slice) => sum + slice.value, 0);
let pieCursor = 0;
const pieStops = shipmentTypeSlices
  .map((slice) => {
    const start = pieCursor;
    pieCursor += (slice.value / totalPie) * 100;
    return `${slice.color} ${start}% ${pieCursor}%`;
  })
  .join(', ');
---

<section class="section-spacing pt-4" id="data-visualization">
  <SectionHeading
    eyebrow="Data Visualization"
    title="Operational analytics preview"
    description="A lightweight charting layer that simulates shipment trends, quality signals, and route efficiency metrics."
  />

  <Container class="mt-10">
    <div class="grid gap-4 md:grid-cols-2">
      <article class="panel border-white/15" data-reveal>
        <h3 class="text-base font-semibold text-white">Monthly Shipments</h3>
        <p class="mt-1 text-xs text-slate-300">Six-month shipment throughput trend.</p>
        <svg viewBox={`0 0 ${chartWidth} ${chartHeight}`} class="mt-4 w-full" aria-label="Monthly shipments line chart">
          <path d={areaPath} fill="url(#lineGradient)" opacity="0.7" />
          <polyline
            points={linePath}
            fill="none"
            stroke="rgba(169, 232, 255, 0.95)"
            stroke-width="3"
            stroke-linecap="round"
            class="data-chart-line"
          />
          {
            linePoints.map((point, index) => (
              <circle
                cx={point.x}
                cy={point.y}
                r="3"
                fill="rgba(248, 254, 255, 0.95)"
                class="data-chart-dot"
                style={`transition-delay:${index * 85}ms`}
              />
            ))
          }
          <defs>
            <linearGradient id="lineGradient" x1="0" y1="0" x2="0" y2="1">
              <stop offset="0" stop-color="rgba(146, 227, 255, 0.5)" />
              <stop offset="1" stop-color="rgba(146, 227, 255, 0.02)" />
            </linearGradient>
          </defs>
        </svg>
      </article>

      <article class="panel border-white/15" data-reveal>
        <h3 class="text-base font-semibold text-white">Delivery Success Rate</h3>
        <p class="mt-1 text-xs text-slate-300">Rolling quality signal from completed deliveries.</p>
        <div class="mt-6 flex items-center justify-center">
          <div
            class="relative flex h-40 w-40 items-center justify-center rounded-full"
            style={`background: conic-gradient(rgba(153,232,255,1) ${deliverySuccessRate}%, rgba(255,255,255,0.2) 0);`}
          >
            <div class="flex h-28 w-28 items-center justify-center rounded-full border border-white/20 bg-ink-900/70">
              <span class="text-2xl font-bold text-white">{deliverySuccessRate}%</span>
            </div>
          </div>
        </div>
      </article>

      <article class="panel border-white/15" data-reveal>
        <h3 class="text-base font-semibold text-white">Shipment Types</h3>
        <p class="mt-1 text-xs text-slate-300">Distribution by service profile.</p>
        <div class="mt-5 flex flex-wrap items-center gap-6">
          <div class="h-36 w-36 rounded-full border border-white/20" style={`background: conic-gradient(${pieStops});`}></div>
          <ul class="space-y-2 text-sm text-slate-200">
            {
              shipmentTypeSlices.map((slice) => (
                <li class="flex items-center gap-2">
                  <span class="inline-flex h-3 w-3 rounded-full" style={`background:${slice.color};`}></span>
                  <span>{slice.label}</span>
                  <span class="text-slate-300">{slice.value}%</span>
                </li>
              ))
            }
          </ul>
        </div>
      </article>

      <article class="panel border-white/15" data-reveal>
        <h3 class="text-base font-semibold text-white">Route Efficiency</h3>
        <p class="mt-1 text-xs text-slate-300">Performance by corridor cluster.</p>

        <div class="mt-6 grid grid-cols-4 gap-3">
          {
            routeEfficiencyBars.map((bar, index) => (
              <div class="text-center" style={`transition-delay:${index * 70}ms`}>
                <div class="relative mx-auto h-28 w-11 overflow-hidden rounded-lg border border-white/15 bg-white/10">
                  <span
                    data-chart-bar
                    style={`--bar-scale:${(bar.value / 100).toFixed(2)}`}
                    class="absolute inset-x-0 bottom-0 mx-auto block h-full w-full rounded-lg bg-gradient-to-t from-cyan-300/70 to-cyan-100/95"
                  ></span>
                </div>
                <p class="mt-2 text-xs font-semibold text-slate-100">{bar.value}%</p>
                <p class="mt-1 text-[11px] text-slate-300">{bar.label}</p>
              </div>
            ))
          }
        </div>
      </article>
    </div>
  </Container>
</section>
