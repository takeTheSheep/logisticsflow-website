---
import Container from '@/components/common/Container.astro';
import SectionHeading from '@/components/common/SectionHeading.astro';
import SystemIcon from '@/components/common/SystemIcon.astro';
import { operationsMetrics, operationsRows } from '@/data/platform';

const statusClassMap = {
  'In Transit': 'border-cyan-200/45 bg-cyan-200/20 text-cyan-50',
  Delivered: 'border-emerald-300/45 bg-emerald-300/20 text-emerald-50',
  Delayed: 'border-amber-300/45 bg-amber-300/20 text-amber-50',
  'Arrived at Hub': 'border-indigo-200/45 bg-indigo-200/20 text-indigo-50',
  'Out for Delivery': 'border-teal-200/45 bg-teal-200/20 text-teal-50',
} as const;
---

<section class="section-spacing pt-4" id="operations-dashboard">
  <SectionHeading
    eyebrow="Live Operations"
    title="Operations dashboard preview"
    description="A product-like operations panel showing shipment activity, status distribution, and lane-level context."
  />

  <Container class="mt-10">
    <div class="section-shell p-6 md:p-8" data-reveal>
      <div class="grid gap-4 sm:grid-cols-2 xl:grid-cols-4">
        {
          operationsMetrics.map((metric) => (
            <article class="rounded-2xl border border-white/15 bg-white/15 p-4">
              <div class="flex items-center justify-between">
                <p class="text-sm font-medium text-slate-200">{metric.title}</p>
                <SystemIcon name={metric.icon} size="sm" />
              </div>
              <p class="mt-3 text-3xl font-bold text-white">{metric.value}</p>
              <p class="mt-2 text-xs text-slate-300">{metric.detail}</p>
            </article>
          ))
        }
      </div>

      <div class="mt-6 overflow-hidden rounded-2xl border border-white/15">
        <table class="w-full border-collapse text-left text-sm">
          <thead class="bg-white/15 text-xs uppercase tracking-[0.1em] text-slate-200">
            <tr>
              <th class="px-4 py-3 font-semibold">Shipment ID</th>
              <th class="px-4 py-3 font-semibold">Route</th>
              <th class="px-4 py-3 font-semibold">ETA</th>
              <th class="px-4 py-3 font-semibold">Status</th>
            </tr>
          </thead>
          <tbody class="bg-white/10 text-slate-100">
            {
              operationsRows.map((row) => (
                <tr class="border-t border-white/10 transition-colors hover:bg-white/15">
                  <td class="px-4 py-3 font-semibold text-cyan-50">{row.shipmentId}</td>
                  <td class="px-4 py-3">{row.route}</td>
                  <td class="px-4 py-3 text-slate-200">{row.eta}</td>
                  <td class="px-4 py-3">
                    <span class={`inline-flex rounded-full border px-2.5 py-1 text-xs font-semibold ${statusClassMap[row.status]}`} data-status-pill>
                      {row.status}
                    </span>
                  </td>
                </tr>
              ))
            }
          </tbody>
        </table>
      </div>
    </div>
  </Container>
</section>
