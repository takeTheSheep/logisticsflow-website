---
import Container from '@/components/common/Container.astro';
import SectionHeading from '@/components/common/SectionHeading.astro';
import ValueBlock from '@/components/common/ValueBlock.astro';
import { valuePillars } from '@/data/company';
---

<section class="section-spacing pt-6">
  <SectionHeading
    eyebrow="Why LogisticsFlow"
    title="Execution quality that improves outcomes across your full logistics cycle."
    description="We focus on delivery confidence, not just status updates."
  />
  <Container class="mt-10">
    <div class="grid gap-4 md:grid-cols-2">
      {
        valuePillars.slice(0, 4).map((pillar) => (
          <ValueBlock title={pillar.title} description={pillar.description} />
        ))
      }
    </div>
  </Container>
</section>
