---
import Container from '@/components/common/Container.astro';
import SectionHeading from '@/components/common/SectionHeading.astro';
import SystemIcon from '@/components/common/SystemIcon.astro';
import { techStackItems } from '@/data/platform';
---

<section class="section-spacing pt-4" id="engineering-stack">
  <SectionHeading
    eyebrow="Engineering"
    title="Built with modern web architecture"
    description="A deliberate technical stack focused on performance, maintainability, and extensibility."
  />

  <Container class="mt-10">
    <div class="grid gap-4 sm:grid-cols-2 xl:grid-cols-4">
      {
        techStackItems.map((item, index) => (
          <article
            class="panel group relative overflow-hidden border-white/15 transition-all duration-300 hover:-translate-y-1 hover:border-cyan-300/45 hover:shadow-glow"
            data-reveal
            style={`transition-delay: ${index * 50}ms`}
          >
            <div class="mb-4 flex items-center justify-between">
              <SystemIcon name={item.icon} />
              <span class="rounded-full border border-white/25 bg-white/15 px-2 py-1 text-[10px] font-semibold uppercase tracking-[0.14em] text-slate-100">
                stack
              </span>
            </div>
            <h3 class="text-lg font-semibold text-white">{item.title}</h3>
            <p class="mt-3 text-sm text-slate-300">{item.description}</p>
          </article>
        ))
      }
    </div>
  </Container>
</section>
