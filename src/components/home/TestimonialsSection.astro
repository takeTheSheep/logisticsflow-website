---
import Container from '@/components/common/Container.astro';
import SectionHeading from '@/components/common/SectionHeading.astro';
import TestimonialCard from '@/components/common/TestimonialCard.astro';
import { testimonials } from '@/data/testimonials';
---

<section class="section-spacing pt-6">
  <SectionHeading
    eyebrow="Client Perspective"
    title="Trusted by operations leaders who need reliable execution"
    description="Representative feedback from logistics teams managing active shipment networks."
  />
  <Container class="mt-10">
    <div class="grid gap-4 md:grid-cols-3">
      {testimonials.map((testimonial) => <TestimonialCard quote={testimonial.quote} role={testimonial.role} />)}
    </div>
  </Container>
</section>
