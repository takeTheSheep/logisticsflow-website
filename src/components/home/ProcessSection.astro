---
import Container from '@/components/common/Container.astro';
import SectionHeading from '@/components/common/SectionHeading.astro';

const steps = [
  {
    title: 'Request',
    detail: 'We scope your lanes, service constraints, and reporting expectations.',
  },
  {
    title: 'Planning',
    detail: 'Route and checkpoint plans are aligned with your delivery priorities.',
  },
  {
    title: 'Dispatch',
    detail: 'Execution starts with milestone monitoring and exception ownership.',
  },
  {
    title: 'Delivery Visibility',
    detail: 'Your team receives clear updates and performance context at every stage.',
  },
];
---

<section class="section-spacing pt-6">
  <SectionHeading
    eyebrow="Process"
    title="A four-step execution flow designed for accountability."
    description="Operational clarity from initial request through final delivery confirmation."
  />

  <Container class="mt-10">
    <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-4">
      {
        steps.map((step, index) => (
          <article class="panel relative border-white/10">
            <span class="absolute -top-2 left-4 rounded-full border border-cyan-300/40 bg-cyan-300/20 px-2 py-0.5 text-xs font-semibold text-cyan-100">
              0{index + 1}
            </span>
            <h3 class="mt-3 text-lg font-semibold text-white">{step.title}</h3>
            <p class="mt-2 text-sm text-slate-300">{step.detail}</p>
          </article>
        ))
      }
    </div>
  </Container>
</section>
