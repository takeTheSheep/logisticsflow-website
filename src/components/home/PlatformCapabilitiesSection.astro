---
import Container from '@/components/common/Container.astro';
import SectionHeading from '@/components/common/SectionHeading.astro';
import SystemIcon from '@/components/common/SystemIcon.astro';
import { platformCapabilities } from '@/data/platform';
---

<section class="section-spacing pt-4" id="platform-capabilities">
  <SectionHeading
    eyebrow="Platform Capabilities"
    title="Operational modules that feel like a product system"
    description="Core logistics capabilities presented as software features, not brochure paragraphs."
  />

  <Container class="mt-10">
    <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-3">
      {
        platformCapabilities.map((capability, index) => (
          <article
            class="panel group border-white/15 transition-all duration-300 hover:-translate-y-1 hover:border-cyan-300/50 hover:shadow-glow"
            data-reveal
            style={`transition-delay: ${index * 55}ms`}
          >
            <div class="mb-4 flex items-center gap-3">
              <SystemIcon name={capability.icon} />
              <h3 class="text-lg font-semibold text-white">{capability.title}</h3>
            </div>
            <p class="text-sm text-slate-300">{capability.description}</p>
            <div class="mt-5 h-1.5 w-full overflow-hidden rounded-full bg-white/10">
              <span class="block h-full w-3/4 rounded-full bg-gradient-to-r from-cyan-200/80 to-teal-200/70 transition-all duration-500 group-hover:w-full"></span>
            </div>
          </article>
        ))
      }
    </div>
  </Container>
</section>
