---
import Container from '@/components/common/Container.astro';
import { trustMetrics } from '@/data/metrics';
---

<section class="pb-10" aria-label="Operations metrics">
  <Container>
    <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-4">
      {
        trustMetrics.map((metric, index) => (
          <article
            class="panel group relative overflow-hidden border-white/15 transition-all duration-300 hover:-translate-y-1 hover:border-cyan-300/45 hover:shadow-glow"
            data-metric-card
            data-reveal
            style={`transition-delay: ${index * 70}ms`}
          >
            <div class="absolute -right-8 -top-10 h-24 w-24 rounded-full bg-cyan-200/15 blur-2xl transition-opacity duration-300 group-hover:opacity-100"></div>
            <p
              class="text-3xl font-bold text-white"
              data-counter-value
              data-target={metric.target ?? ''}
              data-prefix={metric.prefix ?? ''}
              data-suffix={metric.suffix ?? ''}
              data-decimals={metric.decimals ?? 0}
            >
              {metric.value}
            </p>
            <h3 class="mt-2 text-sm font-semibold uppercase tracking-[0.1em] text-cyan-100/90">{metric.label}</h3>
            <p class="mt-3 text-sm text-slate-300">{metric.detail}</p>
          </article>
        ))
      }
    </div>
  </Container>
</section>

<script>
  const metricCards = document.querySelectorAll<HTMLElement>('[data-metric-card]');

  const animateCounter = (element: HTMLElement): void => {
    const target = Number(element.dataset.target || '0');
    if (!Number.isFinite(target) || target <= 0) return;

    const prefix = element.dataset.prefix ?? '';
    const suffix = element.dataset.suffix ?? '';
    const decimals = Number(element.dataset.decimals || '0');
    const duration = 1100;
    const start = performance.now();

    const render = (value: number): void => {
      const formatted = value.toLocaleString('en-US', {
        minimumFractionDigits: decimals,
        maximumFractionDigits: decimals,
      });
      element.textContent = `${prefix}${formatted}${suffix}`;
    };

    const tick = (timestamp: number): void => {
      const progress = Math.min((timestamp - start) / duration, 1);
      const eased = 1 - Math.pow(1 - progress, 3);
      render(target * eased);
      if (progress < 1) {
        requestAnimationFrame(tick);
      }
    };

    requestAnimationFrame(tick);
  };

  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (!entry.isIntersecting) return;
        const card = entry.target as HTMLElement;
        const valueElement = card.querySelector<HTMLElement>('[data-counter-value]');
        if (valueElement) {
          animateCounter(valueElement);
        }
        observer.unobserve(card);
      });
    },
    { threshold: 0.45 }
  );

  metricCards.forEach((card) => observer.observe(card));
</script>
