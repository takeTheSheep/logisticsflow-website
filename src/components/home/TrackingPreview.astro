---
import Container from '@/components/common/Container.astro';
import SectionHeading from '@/components/common/SectionHeading.astro';
import TrackingForm from '@/components/tracking/TrackingForm.astro';
---

<section class="section-spacing pt-6">
  <SectionHeading
    eyebrow="Tracking Demo"
    title="Shipment visibility preview"
    description="See how the tracking experience surfaces status, route, and checkpoint context for operations teams."
  />
  <Container class="mt-10">
    <TrackingForm
      mode="preview"
      title="Check a demo shipment"
      description="Use sample LogisticsFlow IDs to preview how clients get reliable shipment context."
    />
  </Container>
</section>
