---
import Container from '@/components/common/Container.astro';
import SectionHeading from '@/components/common/SectionHeading.astro';
import SystemIcon from '@/components/common/SystemIcon.astro';
import { architectureLayers } from '@/data/platform';
---

<section class="section-spacing pt-4" id="system-architecture">
  <SectionHeading
    eyebrow="System Architecture"
    title="How the logistics system is structured"
    description="A layered architecture model that explains frontend boundaries, tracking logic, and integration readiness."
  />

  <Container class="mt-10">
    <div class="relative rounded-3xl border border-white/20 bg-white/10 p-6 md:p-8" data-reveal>
      <div class="pointer-events-none absolute bottom-8 left-8 top-8 w-px bg-gradient-to-b from-cyan-200/70 via-cyan-200/25 to-transparent"></div>

      <div class="space-y-4 md:space-y-5">
        {
          architectureLayers.map((layer) => (
            <article class="relative rounded-2xl border border-white/15 bg-white/15 p-4 pl-14 md:p-5 md:pl-16">
              <div class="absolute left-4 top-4 md:left-5 md:top-5">
                <SystemIcon name={layer.icon} />
              </div>
              <div class="flex flex-wrap items-center justify-between gap-2">
                <h3 class="text-lg font-semibold text-white">{layer.title}</h3>
                <span class="rounded-full border border-white/25 bg-white/15 px-2.5 py-1 text-xs font-semibold uppercase tracking-[0.12em] text-slate-100">
                  {layer.stack}
                </span>
              </div>
              <p class="mt-2 text-sm text-slate-300">{layer.description}</p>
            </article>
          ))
        }
      </div>
    </div>
  </Container>
</section>
