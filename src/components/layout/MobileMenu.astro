---
import Button from '@/components/common/Button.astro';
import Container from '@/components/common/Container.astro';
import { navigationLinks } from '@/data/navigation';

interface Props {
  pathname: string;
}

const { pathname } = Astro.props as Props;
---

<div
  id="mobile-navigation"
  data-mobile-menu
  aria-hidden="true"
  class="pointer-events-none max-h-0 overflow-hidden border-t border-white/20 bg-ink-900/80 backdrop-blur-xl opacity-0 transition-all duration-300 ease-refined md:hidden"
>
  <Container class="py-4">
    <nav aria-label="Mobile navigation" class="flex flex-col gap-2">
      {
        navigationLinks.map((item) => {
          const isActive = pathname === item.href;
          return (
            <a
              href={item.href}
              class={`rounded-xl px-4 py-3 text-sm font-medium transition-colors ${
                isActive ? 'bg-white/20 text-cyan-50' : 'text-slate-100 hover:bg-white/15 hover:text-white'
              }`}
              data-mobile-link
            >
              {item.label}
            </a>
          );
        })
      }
      <div class="pt-2">
        <Button href="/contact" class="w-full justify-center">
          Request Quote
        </Button>
      </div>
    </nav>
  </Container>
</div>


