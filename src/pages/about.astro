---
import MainLayout from '@/components/layout/MainLayout.astro';
import PageHero from '@/components/common/PageHero.astro';
import Container from '@/components/common/Container.astro';
import ValuePillars from '@/components/about/ValuePillars.astro';
import TeamRoles from '@/components/about/TeamRoles.astro';
import { aboutMetrics } from '@/data/metrics';
import {
  companyMission,
  operationalPhilosophy,
  companyStory,
  valuePillars,
  teamRoles,
} from '@/data/company';

const pathname = Astro.url.pathname;
---

<MainLayout
  title="About LogisticsFlow"
  description="Learn LogisticsFlow's mission, operating philosophy, and value pillars for premium freight and supply chain execution."
  pathname={pathname}
>
  <PageHero
    eyebrow="About"
    title="A logistics brand built around execution discipline"
    description="LogisticsFlow exists to give operations teams better control of freight outcomes through structured visibility and clear communication."
  />

  <section class="section-spacing pt-6">
    <Container>
      <div class="grid gap-4 lg:grid-cols-3">
        <article class="rounded-2xl border border-white/10 bg-white/10 p-6 lg:col-span-2">
          <h2 class="text-xl font-semibold text-white">Mission</h2>
          <p class="mt-3 text-slate-300">{companyMission}</p>
          <h2 class="mt-6 text-xl font-semibold text-white">Operational Philosophy</h2>
          <p class="mt-3 text-slate-300">{operationalPhilosophy}</p>
          <h2 class="mt-6 text-xl font-semibold text-white">Company Story</h2>
          <p class="mt-3 text-slate-300">{companyStory}</p>
        </article>

        <article class="rounded-2xl border border-white/10 bg-white/10 p-6">
          <h2 class="text-lg font-semibold text-white">Operational Snapshot</h2>
          <p class="mt-2 text-sm text-slate-300">Representative metrics from active coordination programs.</p>
          <div class="mt-5 space-y-3">
            {
              aboutMetrics.map((metric) => (
                <div class="rounded-xl border border-white/10 bg-white/10 p-3">
                  <p class="text-xl font-semibold text-cyan-100">{metric.value}</p>
                  <p class="mt-1 text-sm text-slate-200">{metric.label}</p>
                </div>
              ))
            }
          </div>
        </article>
      </div>
    </Container>
  </section>

  <section class="section-spacing pt-4">
    <Container>
      <h2 class="text-3xl font-bold text-white">Value pillars</h2>
      <p class="mt-3 max-w-2xl text-slate-300">The principles guiding every lane strategy, dispatch decision, and client update.</p>
      <div class="mt-8">
        <ValuePillars pillars={valuePillars} />
      </div>
    </Container>
  </section>

  <section class="section-spacing pt-4">
    <Container>
      <h2 class="text-3xl font-bold text-white">Operational team roles</h2>
      <p class="mt-3 max-w-2xl text-slate-300">Clear ownership and accountability across the full shipment lifecycle.</p>
      <div class="mt-8">
        <TeamRoles roles={teamRoles} />
      </div>
    </Container>
  </section>
</MainLayout>


