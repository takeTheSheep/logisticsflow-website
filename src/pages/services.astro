---
import MainLayout from '@/components/layout/MainLayout.astro';
import PageHero from '@/components/common/PageHero.astro';
import Button from '@/components/common/Button.astro';
import Container from '@/components/common/Container.astro';
import ServiceDetailBlock from '@/components/services/ServiceDetailBlock.astro';
import { services } from '@/data/services';

const pathname = Astro.url.pathname;
---

<MainLayout
  title="Logistics Services"
  description="Explore LogisticsFlow service capabilities across freight coordination, warehousing, route planning, and cross-border support."
  pathname={pathname}
>
  <PageHero
    eyebrow="Services"
    title="Logistics services engineered for reliable delivery performance"
    description="Each service module is designed to reduce uncertainty, improve coordination, and increase shipment confidence across your operation."
  />

  <section class="section-spacing pt-6">
    <Container>
      <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
        {
          services.map((service) => (
            <a
              href={`#${service.id}`}
              class="rounded-2xl border border-white/10 bg-white/10 p-4 text-sm font-semibold text-slate-100 transition-all duration-300 hover:-translate-y-0.5 hover:border-cyan-300/50 hover:text-cyan-100"
            >
              {service.title}
            </a>
          ))
        }
      </div>
    </Container>
  </section>

  <section class="section-spacing pt-0">
    <Container>
      <div class="space-y-6">
        {services.map((service) => <ServiceDetailBlock service={service} />)}
      </div>
    </Container>
  </section>

  <section class="section-spacing pt-6">
    <Container>
      <div class="section-shell p-8 md:p-10">
        <h2 class="text-3xl font-bold text-white">Request a logistics consultation</h2>
        <p class="mt-4 max-w-2xl text-slate-300">
          Let us evaluate your freight setup and recommend execution improvements tailored to your shipment profile.
        </p>
        <div class="mt-7">
          <Button href="/contact" size="lg">Book Consultation</Button>
        </div>
      </div>
    </Container>
  </section>
</MainLayout>

