---
import MainLayout from '@/components/layout/MainLayout.astro';
import Container from '@/components/common/Container.astro';
import Button from '@/components/common/Button.astro';

const pathname = Astro.url.pathname;
---

<MainLayout
  title="Page Not Found"
  description="The page you requested could not be found."
  pathname={pathname}
  noIndex={true}
>
  <section class="section-spacing pt-36">
    <Container class="max-w-3xl text-center">
      <p class="text-sm uppercase tracking-[0.12em] text-cyan-200/90">Error 404</p>
      <h1 class="mt-4 text-5xl font-bold text-white">Page not found</h1>
      <p class="mt-4 text-slate-300">
        The route you requested is unavailable. Return to the homepage or explore our service pages.
      </p>
      <div class="mt-8 flex flex-wrap justify-center gap-3">
        <Button href="/" size="lg">Go Home</Button>
        <Button href="/services" size="lg" variant="secondary">View Services</Button>
      </div>
    </Container>
  </section>
</MainLayout>
