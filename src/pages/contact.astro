---
import MainLayout from '@/components/layout/MainLayout.astro';
import PageHero from '@/components/common/PageHero.astro';
import Container from '@/components/common/Container.astro';
import ContactForm from '@/components/contact/ContactForm.astro';
import FAQAccordion from '@/components/contact/FAQAccordion.astro';
import { faqs } from '@/data/company';

const pathname = Astro.url.pathname;
---

<MainLayout
  title="Contact LogisticsFlow"
  description="Contact LogisticsFlow to request freight coordination, warehousing support, or a logistics consultation."
  pathname={pathname}
>
  <PageHero
    eyebrow="Contact"
    title="Talk with our logistics team"
    description="Share your current shipment challenges and service goals. We will recommend a practical execution plan built around your operation."
  />

  <section class="section-spacing pt-6">
    <Container>
      <div class="grid gap-6 xl:grid-cols-[1.2fr_0.8fr]">
        <ContactForm />

        <div class="space-y-6">
          <section class="rounded-3xl border border-white/10 bg-white/10 p-6 md:p-8">
            <h2 class="text-xl font-semibold text-white">Availability</h2>
            <p class="mt-3 text-sm text-slate-300">Monday-Friday, 08:00-19:00 CET with priority exception support for active lanes.</p>
            <div class="mt-5 space-y-3 text-sm text-slate-300">
              <p><span class="font-semibold text-slate-100">General:</span> contact@logisticsflow.example</p>
              <p><span class="font-semibold text-slate-100">Support:</span> ops-support@logisticsflow.example</p>
              <p><span class="font-semibold text-slate-100">Regional Office:</span> Amsterdam Operations Hub</p>
            </div>
          </section>

          <FAQAccordion items={faqs} />
        </div>
      </div>
    </Container>
  </section>
</MainLayout>

