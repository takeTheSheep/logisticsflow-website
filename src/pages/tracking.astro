---
import MainLayout from '@/components/layout/MainLayout.astro';
import PageHero from '@/components/common/PageHero.astro';
import Container from '@/components/common/Container.astro';
import TrackingForm from '@/components/tracking/TrackingForm.astro';
import type { TrackingRecord } from '@/types/tracking';
import { getTrackingRecord } from '@/lib/tracking/getTrackingRecord';
import { normalizeTrackingCode, validateTrackingCode } from '@/lib/tracking/validateTrackingCode';

const pathname = Astro.url.pathname;
const submittedCode = Astro.url.searchParams.get('trackingCode') ?? '';

let initialCode = submittedCode;
let initialError = '';
let initialRecord: TrackingRecord | null = null;

if (submittedCode) {
  const normalizedCode = normalizeTrackingCode(submittedCode);
  initialCode = normalizedCode;

  if (!validateTrackingCode(normalizedCode)) {
    initialError = 'Enter a valid tracking code format like LF-48291.';
  } else {
    const record = getTrackingRecord(normalizedCode);
    if (record) {
      initialRecord = record;
    } else {
      initialError = 'Tracking code not found in demo records. Try one of the sample codes.';
    }
  }
}
---

<MainLayout
  title="Track Your Shipment"
  description="Use the LogisticsFlow tracking demo to validate shipment status, timeline milestones, and operational notes in one view."
  pathname={pathname}
>
  <PageHero
    eyebrow="Tracking"
    title="Track your shipment"
    description="Enter a LogisticsFlow tracking ID for a full shipment status breakdown including route, service level, and timeline checkpoints."
  />

  <section class="section-spacing pt-6">
    <Container class="max-w-4xl">
      <TrackingForm
        mode="full"
        title="Shipment tracking center"
        description="Use demo IDs to preview a production-style tracking interface with validation, loading state, and status timeline."
        action="/tracking"
        initialCode={initialCode}
        initialError={initialError}
        initialRecord={initialRecord}
      />

      <div class="mt-6 rounded-2xl border border-white/10 bg-white/10 p-5 text-sm text-slate-300">
        <p class="font-semibold text-slate-100">Integration boundary</p>
        <p class="mt-2">
          Tracking data is sourced from a local mock module for this demo. The form and record lookup logic are isolated so this can be replaced with a secured API endpoint without UI rework.
        </p>
      </div>
    </Container>
  </section>
</MainLayout>


